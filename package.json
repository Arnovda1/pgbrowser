{
	"name": "pgbrowser",
	"private": true,
	"version": "0.1.0-alpha.1",
	"type": "module",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/Arnovda1/pgbrowser.git"
	},
	"keywords": [
		"postgres",
		"postgresql",
		"database-client",
		"pgadmin",
		"svelte",
		"lightweight"
	],
	"license": "MIT",
	"scripts": {
		"dev": "bun --bun vite dev",
		"build:install": "bun install && bun --bun vite build",
		"build": "bun --bun vite build",
		"preview": "bun --bun vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check .",
		"format": "prettier --write .",
		"test": "bun test",
		"test:e2e": "playwright test"
	},
	"devDependencies": {
		"@codemirror/lang-json": "^6.0.2",
		"@codemirror/lang-sql": "^6.10.0",
		"@dagrejs/dagre": "^3.0.0",
		"@fontsource-variable/inter": "^5.2.8",
		"@fsegurai/codemirror-theme-material-ocean": "^6.0.1",
		"@internationalized/date": "^3.12.0",
		"@lucide/svelte": "^1.17.0",
		"@playwright/test": "^1.60.0",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@tailwindcss/vite": "^4.2.2",
		"@testcontainers/postgresql": "^12.0.2",
		"@types/bun": "^1.3.14",
		"@types/pg": "^8.20.0",
		"axios": "^1.16.1",
		"bits-ui": "^2.18.1",
		"clsx": "^2.1.1",
		"codemirror": "^6.0.2",
		"formsnap": "^2.0.1",
		"lucide-svelte": "^1.0.1",
		"paneforge": "^1.0.2",
		"postgres": "^3.4.9",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"shadcn-svelte": "^1.2.7",
		"sql-formatter": "^15.8.0",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"svelte-codemirror-editor": "^2.1.0",
		"sveltekit-exec-adapter": "^0.4.0",
		"sveltekit-superforms": "^2.30.1",
		"svelvet": "^11.0.5",
		"tailwind-merge": "^3.5.0",
		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.2.2",
		"testcontainers": "^12.0.2",
		"tw-animate-css": "^1.4.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"zod": "^4.4.3"
	},
	"dependencies": {}
}